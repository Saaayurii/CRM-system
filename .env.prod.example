# =============================================================
# CRM System — Master Environment File
# Copy to .env and fill in production values before deploying.
# =============================================================

# ── General ──────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=construction_crm
# Exposed host port (admin access only; nginx/backend talk via Docker network)
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────
# Generate strong random secrets for production, e.g.:
#   openssl rand -hex 64
JWT_ACCESS_SECRET=change-this-to-a-strong-random-secret-access
JWT_REFRESH_SECRET=change-this-to-a-strong-random-secret-refresh
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Security ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── CORS ─────────────────────────────────────────────────────
# In production set to your real domain, e.g. https://crm.example.com
CORS_ORIGIN=http://localhost

# ── Public URL (for building absolute file URLs) ─────────────
# Set to your domain in production, e.g. https://crm.example.com
APP_PUBLIC_URL=http://localhost

# ── Frontend build args (baked into the JS bundle) ───────────
# /api/v1 is relative — nginx routes it to api-gateway
NEXT_PUBLIC_API_URL=/api/v1
# WebSocket URL for chat (relative path, nginx handles upgrade)
NEXT_PUBLIC_CHAT_WS_URL=
# VAPID public key for Web Push notifications (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Nginx ────────────────────────────────────────────────────
NGINX_PORT=80
NGINX_PORT_SSL=443

# ── Admin tools (only active with --profile admin) ───────────
PGADMIN_EMAIL=admin@crm.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
REDIS_COMMANDER_PORT=8081
