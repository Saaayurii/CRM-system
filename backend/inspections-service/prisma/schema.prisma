generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  status    Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  inspections                  Inspection[]
  inspectionChecklistTemplates InspectionChecklistTemplate[]
  defects                      Defect[]
  defectTemplates              DefectTemplate[]
  controlPoints                ControlPoint[]
  sitePlans                    SitePlan[]
  hseRisks                     HseRisk[]
  hseIncidents                 HseIncident[]
  hsePermits                   HsePermit[]
  hseViolations                HseViolation[]
  hseCorrectiveActions         HseCorrectiveAction[]
  hseMonitoring                HseMonitoring[]

  @@map("accounts")
}

// Контрольный пункт (конструктор чек-листов) — самостоятельная сущность-библиотека.
// Базовые фильтруемые поля вынесены в колонки, остальные данные шагов мастера — в JSON.
model ControlPoint {
  id               Int      @id @default(autoincrement())
  accountId        Int      @map("account_id")
  code             String?  @db.VarChar(100)
  version          String   @default("1.0") @db.VarChar(20)
  status           String   @default("draft") @db.VarChar(20) // draft | active | archived
  name             String   @db.VarChar(500)
  description      String?  @db.Text
  section          String?  @db.VarChar(255)
  subsection       String?  @db.VarChar(255)
  checkType        String?  @map("check_type") @db.VarChar(50) // visual | measuring | functional | documentary | complex
  criticality      Int      @default(2)
  weight           Int      @default(100)
  required         Boolean  @default(true)
  normativeDoc     String?  @map("normative_doc") @db.VarChar(255)
  normativeSection String?  @map("normative_section") @db.VarChar(100)
  instruction      String?  @db.Text
  scheme           Json     @default("{}") // { type, imageUrl, pins: [{ n, x, y, label, color }] }
  settings         Json     @default("{}") // фото/видео, доп.настройки, объект, теги, sortOrder и т.п.
  typicalDefects   Json     @default("[]") @map("typical_defects") // шаг 2
  textTemplates    Json     @default("{}") @map("text_templates")  // шаг 3
  reportSettings   Json     @default("{}") @map("report_settings") // шаг 4
  publication      Json     @default("{}") // шаг 5: область действия, совместимость, связанные шаблоны
  versions         Json     @default("[]") // история версий
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([status])
  @@map("control_points")
}

model Inspection {
  id                 Int       @id @default(autoincrement())
  accountId          Int       @map("account_id")
  projectId          Int?      @map("project_id")
  constructionSiteId Int?      @map("construction_site_id")
  taskId             Int?      @map("task_id")
  qualityStandardId  Int?      @map("quality_standard_id")
  inspectionNumber   String    @unique @map("inspection_number") @db.VarChar(100)
  inspectionType     String?   @map("inspection_type") @db.VarChar(100)
  inspectorId        Int?      @map("inspector_id")
  scheduledDate      DateTime? @map("scheduled_date") @db.Date
  actualDate         DateTime? @map("actual_date") @db.Date
  status             Int       @default(0)
  result             String?   @db.VarChar(50)
  inspectionArea     String?   @map("inspection_area") @db.VarChar(255)
  description        String?   @db.Text
  findings           String?   @db.Text
  recommendations    String?   @db.Text
  score              Int?
  photos             Json      @default("[]")
  documents          Json      @default("[]")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  account          Account                      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  checklistResults InspectionChecklistResult[]
  defects          Defect[]

  @@index([accountId])
  @@index([projectId])
  @@index([constructionSiteId])
  @@index([inspectorId])
  @@map("inspections")
}

model InspectionChecklistTemplate {
  id             Int      @id @default(autoincrement())
  accountId      Int      @map("account_id")
  name           String   @db.VarChar(255)
  inspectionType String?  @map("inspection_type") @db.VarChar(100)
  checklistItems Json     @default("[]") @map("checklist_items")
  settings       Json     @default("{}")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  account          Account                     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  checklistResults InspectionChecklistResult[]

  @@map("inspection_checklist_templates")
}

model InspectionChecklistResult {
  id                  Int      @id @default(autoincrement())
  inspectionId        Int      @map("inspection_id")
  checklistTemplateId Int?     @map("checklist_template_id")
  results             Json     @default("[]")
  createdAt           DateTime @default(now()) @map("created_at")

  inspection         Inspection                   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistTemplate  InspectionChecklistTemplate?  @relation(fields: [checklistTemplateId], references: [id])

  @@map("inspection_checklist_results")
}

model Defect {
  id                    Int       @id @default(autoincrement())
  accountId             Int       @map("account_id")
  projectId             Int?      @map("project_id")
  constructionSiteId    Int?      @map("construction_site_id")
  taskId                Int?      @map("task_id")
  inspectionId          Int?      @map("inspection_id")
  planId                Int?      @map("plan_id")
  defectNumber          String    @unique @map("defect_number") @db.VarChar(100)
  defectType            String?   @map("defect_type") @db.VarChar(100)
  category              String?   @db.VarChar(100)
  severity              Int?
  title                 String    @db.VarChar(255)
  description           String?   @db.Text
  locationDescription   String?   @map("location_description") @db.Text
  coordinates           Json?
  reportedByUserId      Int?      @map("reported_by_user_id")
  assignedToUserId      Int?      @map("assigned_to_user_id")
  verifiedByUserId      Int?      @map("verified_by_user_id")
  status                Int       @default(0)
  reportedDate          DateTime  @map("reported_date") @db.Date
  dueDate               DateTime? @map("due_date") @db.Date
  fixedDate             DateTime? @map("fixed_date") @db.Date
  verifiedDate          DateTime? @map("verified_date") @db.Date
  correctionDescription String?   @map("correction_description") @db.Text
  correctionCost        Decimal?  @map("correction_cost") @db.Decimal(10, 2)
  photos                Json      @default("[]")
  documents             Json      @default("[]")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  account    Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  inspection Inspection?     @relation(fields: [inspectionId], references: [id])
  plan       SitePlan?       @relation(fields: [planId], references: [id])
  comments   DefectComment[]

  @@index([accountId])
  @@index([projectId])
  @@index([constructionSiteId])
  @@index([status])
  @@index([planId])
  @@map("defects")
}

// План / чертёж объекта (этаж, фасад, разрез) — растровая подложка, на которой
// дефекты расставляются пинами. Координаты пина хранятся в Defect.coordinates
// как { x, y } (доли 0..1 от размеров изображения, как в ControlPoint.scheme).
model SitePlan {
  id                 Int       @id @default(autoincrement())
  accountId          Int       @map("account_id")
  projectId          Int?      @map("project_id")
  constructionSiteId Int?      @map("construction_site_id")
  title              String    @db.VarChar(255)
  description        String?   @db.Text
  imageUrl           String    @map("image_url") @db.Text
  width              Int?
  height             Int?
  sortOrder          Int       @default(0) @map("sort_order")
  createdByUserId    Int?      @map("created_by_user_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  defects Defect[]

  @@index([accountId, deletedAt])
  @@index([projectId])
  @@index([constructionSiteId])
  @@map("site_plans")
}

model DefectComment {
  id          Int      @id @default(autoincrement())
  defectId    Int      @map("defect_id")
  accountId   Int      @map("account_id")
  userId      Int?     @map("user_id")
  userName    String?  @map("user_name") @db.VarChar(255)
  commentText String   @default("") @map("comment_text") @db.Text
  attachments Json     @default("[]") // [{ url, name, mimeType, kind: 'image'|'audio'|'file', size }]
  createdAt   DateTime @default(now()) @map("created_at")

  defect Defect @relation(fields: [defectId], references: [id], onDelete: Cascade)

  @@index([defectId])
  @@map("defect_comments")
}

model DefectTemplate {
  id              Int      @id @default(autoincrement())
  accountId       Int      @map("account_id")
  defectType      String?  @map("defect_type") @db.VarChar(100)
  category        String?  @db.VarChar(100)
  title           String?  @db.VarChar(255)
  description     String?  @db.Text
  severity        Int?
  typicalCost     Decimal? @map("typical_cost") @db.Decimal(10, 2)
  fixInstructions String?  @map("fix_instructions") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("defect_templates")
}

// ============================================================
// HSE Module
// ============================================================

model HseRisk {
  id                 Int       @id @default(autoincrement())
  accountId          Int       @map("account_id")
  projectId          Int?      @map("project_id")
  constructionSiteId Int?      @map("construction_site_id")
  riskCode           String?   @map("risk_code") @db.VarChar(50)
  category           String?   @db.VarChar(100)
  hazardSource       String?   @map("hazard_source") @db.VarChar(255)
  title              String    @db.VarChar(255)
  description        String?   @db.Text
  likelihood         Int       @default(1)
  severity           Int       @default(1)
  riskLevel          String?   @map("risk_level") @db.VarChar(20)
  controlMeasures    String?   @map("control_measures") @db.Text
  responsibleUserId  Int?      @map("responsible_user_id")
  status             String    @default("identified") @db.VarChar(30)
  identifiedAt       DateTime? @default(now()) @map("identified_at") @db.Date
  reviewDate         DateTime? @map("review_date") @db.Date
  lastReviewedAt     DateTime? @map("last_reviewed_at") @db.Date
  attachments        Json      @default("[]")
  createdByUserId    Int?      @map("created_by_user_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, deletedAt])
  @@index([projectId])
  @@index([accountId, status])
  @@map("hse_risks")
}

model HseIncident {
  id                  Int       @id @default(autoincrement())
  accountId           Int       @map("account_id")
  incidentNumber      String?   @map("incident_number") @db.VarChar(50)
  projectId           Int?      @map("project_id")
  constructionSiteId  Int?      @map("construction_site_id")
  incidentType        String    @map("incident_type") @db.VarChar(50)
  severity            String    @default("medium") @db.VarChar(20)
  occurredAt          DateTime  @map("occurred_at")
  location            String?   @db.VarChar(255)
  description         String    @db.Text
  victimUserId        Int?      @map("victim_user_id")
  victimName          String?   @map("victim_name") @db.VarChar(255)
  victimPosition      String?   @map("victim_position") @db.VarChar(255)
  reportedByUserId    Int?      @map("reported_by_user_id")
  witnesses           Json      @default("[]")
  immediateActions    String?   @map("immediate_actions") @db.Text
  rootCause           String?   @map("root_cause") @db.Text
  investigationStatus String    @default("new") @map("investigation_status") @db.VarChar(30)
  daysLost            Int?      @map("days_lost")
  estimatedCost       Decimal?  @map("estimated_cost") @db.Decimal(14, 2)
  attachments         Json      @default("[]")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, deletedAt])
  @@index([projectId])
  @@index([accountId, incidentType])
  @@index([occurredAt])
  @@map("hse_incidents")
}

model HsePermit {
  id                  Int       @id @default(autoincrement())
  accountId           Int       @map("account_id")
  permitNumber        String?   @map("permit_number") @db.VarChar(50)
  permitType          String    @map("permit_type") @db.VarChar(50)
  projectId           Int?      @map("project_id")
  constructionSiteId  Int?      @map("construction_site_id")
  workDescription     String    @map("work_description") @db.Text
  location            String?   @db.VarChar(255)
  requestedByUserId   Int?      @map("requested_by_user_id")
  approvedByUserId    Int?      @map("approved_by_user_id")
  workers             Json      @default("[]")
  hazards             Json      @default("[]")
  controlMeasures     String?   @map("control_measures") @db.Text
  ppeRequired         Json      @default("[]") @map("ppe_required")
  validFrom           DateTime  @map("valid_from")
  validUntil          DateTime  @map("valid_until")
  status              String    @default("draft") @db.VarChar(30)
  approvedAt          DateTime? @map("approved_at")
  closedAt            DateTime? @map("closed_at")
  closingNotes        String?   @map("closing_notes") @db.Text
  attachments         Json      @default("[]")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, deletedAt])
  @@index([projectId])
  @@index([accountId, status])
  @@index([validUntil])
  @@map("hse_permits")
}

model HseViolation {
  id                  Int       @id @default(autoincrement())
  accountId           Int       @map("account_id")
  projectId           Int?      @map("project_id")
  constructionSiteId  Int?      @map("construction_site_id")
  observedByUserId    Int?      @map("observed_by_user_id")
  violatorUserId      Int?      @map("violator_user_id")
  violatorName        String?   @map("violator_name") @db.VarChar(255)
  contractorId        Int?      @map("contractor_id")
  category            String?   @db.VarChar(100)
  description         String    @db.Text
  severity            String    @default("medium") @db.VarChar(20)
  observedAt          DateTime  @map("observed_at")
  location            String?   @db.VarChar(255)
  photos              Json      @default("[]")
  status              String    @default("open") @db.VarChar(30)
  correctiveAction    String?   @map("corrective_action") @db.Text
  deadline            DateTime? @db.Date
  resolvedAt          DateTime? @map("resolved_at")
  resolutionNotes     String?   @map("resolution_notes") @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, deletedAt])
  @@index([projectId])
  @@index([accountId, status])
  @@index([violatorUserId])
  @@map("hse_violations")
}

model HseCorrectiveAction {
  id                  Int       @id @default(autoincrement())
  accountId           Int       @map("account_id")
  sourceType          String?   @map("source_type") @db.VarChar(30)
  sourceId            Int?      @map("source_id")
  projectId           Int?      @map("project_id")
  constructionSiteId  Int?      @map("construction_site_id")
  title               String    @db.VarChar(255)
  description         String?   @db.Text
  assignedToUserId    Int?      @map("assigned_to_user_id")
  assignedByUserId    Int?      @map("assigned_by_user_id")
  priority            String    @default("medium") @db.VarChar(20)
  dueDate             DateTime? @map("due_date") @db.Date
  status              String    @default("open") @db.VarChar(30)
  completedAt         DateTime? @map("completed_at")
  completionNotes     String?   @map("completion_notes") @db.Text
  attachments         Json      @default("[]")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, deletedAt])
  @@index([assignedToUserId, status])
  @@index([sourceType, sourceId])
  @@index([dueDate, status])
  @@map("hse_corrective_actions")
}

model HseMonitoring {
  id                  Int       @id @default(autoincrement())
  accountId           Int       @map("account_id")
  projectId           Int?      @map("project_id")
  constructionSiteId  Int?      @map("construction_site_id")
  parameterType       String    @map("parameter_type") @db.VarChar(50)
  parameterLabel      String?   @map("parameter_label") @db.VarChar(100)
  value               Decimal?  @db.Decimal(14, 4)
  valueText           String?   @map("value_text") @db.VarChar(255)
  unit                String?   @db.VarChar(50)
  thresholdMin        Decimal?  @map("threshold_min") @db.Decimal(14, 4)
  thresholdMax        Decimal?  @map("threshold_max") @db.Decimal(14, 4)
  status              String    @default("normal") @db.VarChar(20)
  measuredAt          DateTime  @map("measured_at")
  measuredByUserId    Int?      @map("measured_by_user_id")
  notes               String?   @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([projectId])
  @@index([measuredAt])
  @@index([accountId, status, measuredAt])
  @@map("hse_monitoring")
}
