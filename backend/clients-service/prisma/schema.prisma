generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  status    Int      @default(1)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at")
  clients    Client[]
  users      User[]
  deals      Deal[]
  dealStages DealStage[]

  @@map("accounts")
}

// Минимальное представление пользователя — нужно для авто-создания при выдаче доступа клиенту в портал
model User {
  id                 Int       @id @default(autoincrement())
  accountId          Int       @map("account_id")
  roleId             Int?      @map("role_id")
  name               String    @db.VarChar(255)
  email              String    @db.VarChar(255)
  passwordDigest     String?   @map("password_digest") @db.VarChar(255)
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("users")
}

// Минимальное представление проекта — нужно для подстановки имени проекта в название чата
model Project {
  id        Int      @id @default(autoincrement())
  accountId Int?     @map("account_id")
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("projects")
}

model Client {
  id                Int      @id @default(autoincrement())
  accountId         Int      @map("account_id")
  clientType        String?  @map("client_type") @db.VarChar(50)
  firstName         String?  @map("first_name") @db.VarChar(255)
  lastName          String?  @map("last_name") @db.VarChar(255)
  middleName        String?  @map("middle_name") @db.VarChar(255)
  companyName       String?  @map("company_name") @db.VarChar(255)
  legalName         String?  @map("legal_name") @db.VarChar(255)
  inn               String?  @db.VarChar(50)
  kpp               String?  @db.VarChar(50)
  ogrn              String?  @db.VarChar(20)
  phone             String?  @db.VarChar(50)
  email             String?  @db.VarChar(255)
  address           String?  @db.Text
  legalAddress      String?  @map("legal_address") @db.Text
  actualAddress     String?  @map("actual_address") @db.Text
  signatoryName     String?  @map("signatory_name") @db.VarChar(255)
  signatoryPosition String?  @map("signatory_position") @db.VarChar(255)
  assignedManagerId Int?     @map("assigned_manager_id")
  status            String?  @db.VarChar(50)
  source            String?  @db.VarChar(100)
  notes             String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  account      Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  interactions ClientInteraction[]
  portalAccess ClientPortalAccess[]
  deals        Deal[]

  @@index([accountId])
  @@index([assignedManagerId])
  @@map("clients")
}

// Стадия воронки продаж — настраивается на уровне аккаунта (колонки Kanban).
model DealStage {
  id        Int      @id @default(autoincrement())
  accountId Int      @map("account_id")
  name      String   @db.VarChar(255)
  color     String   @default("#64748b") @db.VarChar(20)
  sortOrder Int      @default(0) @map("sort_order")
  isWon     Boolean  @default(false) @map("is_won")
  isLost    Boolean  @default(false) @map("is_lost")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  deals   Deal[]

  @@index([accountId])
  @@map("deal_stages")
}

// Сделка (карточка воронки продаж).
model Deal {
  id                Int       @id @default(autoincrement())
  accountId         Int       @map("account_id")
  stageId           Int       @map("stage_id")
  clientId          Int?      @map("client_id")
  projectId         Int?      @map("project_id")
  title             String    @db.VarChar(255)
  description       String?   @db.Text
  amount            Decimal?  @db.Decimal(14, 2)
  currency          String    @default("RUB") @db.VarChar(10)
  status            String    @default("open") @db.VarChar(20) // open | won | lost
  assignedManagerId Int?      @map("assigned_manager_id")
  expectedCloseDate DateTime? @map("expected_close_date") @db.Date
  source            String?   @db.VarChar(100)
  sortOrder         Int       @default(0) @map("sort_order")
  wonAt             DateTime? @map("won_at")
  lostAt            DateTime? @map("lost_at")
  lostReason        String?   @map("lost_reason") @db.Text
  createdByUserId   Int?      @map("created_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  account Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  stage   DealStage @relation(fields: [stageId], references: [id])
  client  Client?   @relation(fields: [clientId], references: [id])

  @@index([accountId, stageId])
  @@index([clientId])
  @@index([assignedManagerId])
  @@map("deals")
}

model ClientInteraction {
  id              Int       @id @default(autoincrement())
  clientId        Int       @map("client_id")
  userId          Int?      @map("user_id")
  interactionType String?   @map("interaction_type") @db.VarChar(100)
  interactionDate DateTime  @map("interaction_date")
  subject         String?   @db.VarChar(255)
  notes           String?   @db.Text
  outcome         String?   @db.VarChar(100)
  nextAction      String?   @map("next_action") @db.VarChar(255)
  nextActionDate  DateTime? @map("next_action_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_interactions")
}

model ClientPortalAccess {
  id               Int       @id @default(autoincrement())
  clientId         Int       @map("client_id")
  projectId        Int       @map("project_id")
  accessToken      String?   @unique @map("access_token") @db.VarChar(255)
  login            String?   @db.VarChar(255)
  passwordHash     String?   @map("password_hash") @db.VarChar(255)
  userId           Int?      @map("user_id")
  canViewProgress  Boolean   @default(true) @map("can_view_progress")
  canViewPhotos    Boolean   @default(true) @map("can_view_photos")
  canViewDocuments Boolean   @default(false) @map("can_view_documents")
  canViewFinancials Boolean  @default(false) @map("can_view_financials")
  isActive         Boolean   @default(true) @map("is_active")
  expiresAt        DateTime? @map("expires_at")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("client_portal_access")
}

model ClientInvite {
  id                Int       @id @default(autoincrement())
  token             String    @unique @db.VarChar(64)
  accountId         Int       @map("account_id")
  projectId         Int?      @map("project_id")
  createdByUserId   Int?      @map("created_by_user_id")
  note              String?   @db.VarChar(255)
  canViewProgress   Boolean   @default(true) @map("can_view_progress")
  canViewPhotos     Boolean   @default(true) @map("can_view_photos")
  canViewDocuments  Boolean   @default(false) @map("can_view_documents")
  canViewFinancials Boolean   @default(false) @map("can_view_financials")
  expiresAt         DateTime? @map("expires_at")
  usedAt            DateTime? @map("used_at")
  usedByClientId    Int?      @map("used_by_client_id")
  usedByUserId      Int?      @map("used_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([accountId])
  @@map("client_invites")
}
