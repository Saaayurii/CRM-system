generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  status    Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  chatChannels ChatChannel[]
  chatTopics   ChatTopic[]

  @@map("accounts")
}

model User {
  id        Int     @id @default(autoincrement())
  accountId Int     @map("account_id")
  name      String  @db.VarChar(255)
  email     String  @unique @db.VarChar(255)
  avatarUrl String? @map("avatar_url") @db.VarChar(500)
  isActive  Boolean @default(true) @map("is_active")

  chatChannelMembers ChatChannelMember[]
  chatMessages       ChatMessage[]

  @@map("users")
}

model ChatChannel {
  id                 Int      @id @default(autoincrement())
  accountId          Int      @map("account_id")
  channelType        String?  @map("channel_type") @db.VarChar(50)
  name               String?  @db.VarChar(255)
  description        String?  @db.Text
  projectId          Int?     @map("project_id")
  constructionSiteId Int?     @map("construction_site_id")
  teamId             Int?     @map("team_id")
  createdByUserId    Int?     @map("created_by_user_id")
  isPrivate          Boolean  @default(false) @map("is_private")
  settings           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  account  Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  members  ChatChannelMember[]
  messages ChatMessage[]
  topics   ChatTopic[]

  @@map("chat_channels")
}

model ChatChannelMember {
  id         Int       @id @default(autoincrement())
  channelId  Int       @map("channel_id")
  userId     Int       @map("user_id")
  role       String?   @db.VarChar(50)
  // Персональные ограничения сверх прав канала: null = наследует,
  // { "<key>": false } = запрещено этому участнику (ключи как в settings.permissions).
  permissions Json?
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")
  isMuted    Boolean   @default(false) @map("is_muted")
  isArchived Boolean   @default(false) @map("is_archived")
  isPinned   Boolean   @default(false) @map("is_pinned")
  pinnedAt   DateTime? @map("pinned_at")
  mutedUntil DateTime? @map("muted_until")

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("chat_channel_members")
}

model ChatTopic {
  id              Int       @id @default(autoincrement())
  channelId       Int       @map("channel_id")
  accountId       Int       @map("account_id")
  name            String    @db.VarChar(255)
  iconEmoji       String?   @map("icon_emoji") @db.VarChar(32)
  color           String?   @db.VarChar(20)
  createdByUserId Int?      @map("created_by_user_id")
  isGeneral       Boolean   @default(false) @map("is_general")
  isClosed        Boolean   @default(false) @map("is_closed")
  // Кто может писать в теме: 'all' | 'admins' | 'custom' (владелец/админы +
  // перечисленные в allowedUserIds).
  postPermission  String    @default("all") @map("post_permission") @db.VarChar(20)
  // При postPermission='custom' — JSON-массив id пользователей, кому разрешена запись.
  allowedUserIds  Json?     @map("allowed_user_ids")
  isPinned        Boolean   @default(false) @map("is_pinned")
  pinnedAt        DateTime? @map("pinned_at")
  sortOrder       Int       @default(0) @map("sort_order")
  lastMessageAt   DateTime? @map("last_message_at")
  pinnedMessages  Json      @default("[]") @map("pinned_messages")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  channel  ChatChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  account  Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  reads    ChatTopicRead[]

  @@index([channelId])
  @@map("chat_topics")
}

model ChatTopicRead {
  id         Int       @id @default(autoincrement())
  topicId    Int       @map("topic_id")
  userId     Int       @map("user_id")
  lastReadAt DateTime? @map("last_read_at")
  isMuted    Boolean   @default(false) @map("is_muted")
  mutedUntil DateTime? @map("muted_until")
  isHidden   Boolean   @default(false) @map("is_hidden")

  topic ChatTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@index([userId])
  @@map("chat_topic_reads")
}

model ChatMessage {
  id               Int       @id @default(autoincrement())
  channelId        Int       @map("channel_id")
  topicId          Int?      @map("topic_id")
  userId           Int?      @map("user_id")
  messageText      String?   @map("message_text") @db.Text
  messageType      String    @default("text") @map("message_type") @db.VarChar(50)
  attachments      Json      @default("[]")
  replyToMessageId Int?      @map("reply_to_message_id")
  reactions        Json      @default("{}")
  isEdited         Boolean   @default(false) @map("is_edited")
  editedAt         DateTime? @map("edited_at")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  channel        ChatChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  topic          ChatTopic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  user           User?        @relation(fields: [userId], references: [id])
  replyToMessage ChatMessage? @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies        ChatMessage[] @relation("MessageReplies")

  @@index([channelId])
  @@index([topicId])
  @@index([userId])
  @@index([createdAt])
  @@map("chat_messages")
}

// Отложенные сообщения («Отправить позже»). Доставляются BullMQ-воркером
// в назначенное время; отдельная таблица, чтобы не смешивать с лентой.
model ChatScheduledMessage {
  id               Int      @id @default(autoincrement())
  channelId        Int      @map("channel_id")
  userId           Int      @map("user_id")
  topicId          Int?     @map("topic_id")
  messageText      String?  @map("message_text") @db.Text
  messageType      String   @default("text") @map("message_type") @db.VarChar(50)
  attachments      Json     @default("[]")
  replyToMessageId Int?     @map("reply_to_message_id")
  silent           Boolean  @default(false)
  scheduledAt      DateTime @map("scheduled_at")
  jobId            String?  @map("job_id") @db.VarChar(120)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([channelId, userId])
  @@index([scheduledAt])
  @@map("chat_scheduled_messages")
}
