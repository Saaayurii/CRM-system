// ===========================================
// Prisma Schema for Auth Service
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// Account (Organization/Company - Multi-tenancy)
// ===========================================
model Account {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  subdomain String?  @unique @db.VarChar(100)
  settings  Json     @default("{}")
  status    Int      @default(1) // 0-inactive, 1-active, 2-suspended
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  users                User[]
  registrationRequests RegistrationRequest[]

  @@map("accounts")
}

// ===========================================
// Role
// ===========================================
model Role {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  permissions Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

// ===========================================
// User
// ===========================================
model User {
  id         Int     @id @default(autoincrement())
  accountId  Int     @map("account_id")
  roleId     Int?    @map("role_id")
  name       String  @db.VarChar(255)
  email      String  @db.VarChar(255) // uniqueness enforced via partial index (deleted_at IS NULL) in DB
  phone      String? @db.VarChar(50)
  avatarUrl  String? @map("avatar_url") @db.VarChar(500)

  // Status
  availability Int     @default(1) // 0-offline, 1-online, 2-busy, 3-vacation, 4-sick
  isActive     Boolean @default(true) @map("is_active")

  // Authorization
  passwordDigest      String?   @map("password_digest") @db.VarChar(255)
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  confirmedAt    DateTime? @map("confirmed_at")
  lastSignInAt   DateTime? @map("last_sign_in_at")
  currentSignInAt DateTime? @map("current_sign_in_at")
  signInCount    Int       @default(0) @map("sign_in_count")

  // Refresh Token (added for JWT auth)
  refreshToken          String?   @map("refresh_token") @db.VarChar(500)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")

  // Additional Info
  position     String? @db.VarChar(255)
  hireDate     DateTime? @map("hire_date") @db.Date
  birthDate    DateTime? @map("birth_date") @db.Date
  passportData Json?   @map("passport_data")
  address      String? @db.Text

  // Settings
  settings             Json @default("{}")
  notificationSettings Json @default("{}") @map("notification_settings")

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role    Role?   @relation(fields: [roleId], references: [id])

  reviewedRequests RegistrationRequest[] @relation("ReviewedBy")
  sessions         UserSession[]

  @@index([accountId], name: "idx_users_account")
  @@index([roleId], name: "idx_users_role")
  @@index([email], name: "idx_users_email")
  @@index([accountId, isActive], name: "idx_users_active")
  @@map("users")
}

// ===========================================
// UserSession (Active device sessions)
// ===========================================
model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  expiresAt    DateTime @map("expires_at")
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId], name: "idx_user_sessions_user")
  @@map("user_sessions")
}

// ===========================================
// Company Invite Tokens
// =====================
model CompanyInvite {
  id              Int       @id @default(autoincrement())
  token           String    @unique @db.VarChar(64)
  createdBy       Int       @map("created_by")
  note            String?   @db.VarChar(255)
  expiresAt       DateTime? @map("expires_at")
  usedAt          DateTime? @map("used_at")
  usedByAccountId Int?      @map("used_by_account_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("company_invites")
}

// ===========================================
// Member Invite Tokens (Admin/HR → invite employee to company)
// ===========================================
model MemberInvite {
  id               Int       @id @default(autoincrement())
  token            String    @unique @db.VarChar(64)
  accountId        Int       @map("account_id")
  createdByUserId  Int       @map("created_by_user_id")
  note             String?   @db.VarChar(255)
  expiresAt        DateTime? @map("expires_at")
  usedAt           DateTime? @map("used_at")
  usedByUserId     Int?      @map("used_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("member_invites")
}

// Registration Request (Заявки на регистрацию)
// ===========================================
model RegistrationRequest {
  id             Int       @id @default(autoincrement())
  accountId      Int       @default(1) @map("account_id")
  name           String    @db.VarChar(255)
  email          String    @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  birthDate      DateTime? @map("birth_date") @db.Date
  passwordDigest String    @map("password_digest") @db.VarChar(255)
  status         Int       @default(0) // 0=pending, 1=approved, 2=rejected
  rejectReason   String?   @map("reject_reason") @db.Text
  reviewedBy     Int?      @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  account  Account @relation(fields: [accountId], references: [id])
  reviewer User?   @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@map("registration_requests")
}

// ===========================================
// Client Portal Access — нужен auth-service для login/magic-flow клиентов
// ===========================================
model ClientPortalAccess {
  id                Int       @id @default(autoincrement())
  clientId          Int       @map("client_id")
  projectId         Int       @map("project_id")
  accessToken       String?   @unique @map("access_token") @db.VarChar(255)
  login             String?   @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  userId            Int?      @map("user_id")
  canViewProgress   Boolean   @default(true) @map("can_view_progress")
  canViewPhotos     Boolean   @default(true) @map("can_view_photos")
  canViewDocuments  Boolean   @default(false) @map("can_view_documents")
  canViewFinancials Boolean   @default(false) @map("can_view_financials")
  isActive          Boolean   @default(true) @map("is_active")
  expiresAt         DateTime? @map("expires_at")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([userId])
  @@map("client_portal_access")
}

// ===========================================
// Password Reset Token (Email account recovery)
// Один токен на email — покрывает все аккаунты пользователя
// (клиент / админ / разные компании). Хранится только хеш.
// ===========================================
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  email     String    @db.VarChar(255)
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tokenHash], name: "idx_prt_token_hash")
  @@index([email], name: "idx_prt_email")
  @@map("password_reset_tokens")
}

// ===========================================
// Account Recovery Log — кто восстановил аккаунт
// Изолирован по accountId (видят админы своей компании)
// ===========================================
model AccountRecoveryLog {
  id          Int      @id @default(autoincrement())
  accountId   Int      @map("account_id")
  userId      Int      @map("user_id")
  email       String   @db.VarChar(255)
  userName    String?  @map("user_name") @db.VarChar(255)
  roleId      Int?     @map("role_id")
  accountName String?  @map("account_name") @db.VarChar(255)
  method      String   @default("email") @db.VarChar(20) // email | phone
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  recoveredAt DateTime @default(now()) @map("recovered_at")

  @@index([accountId], name: "idx_arl_account")
  @@map("account_recovery_log")
}
