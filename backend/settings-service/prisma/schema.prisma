generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  subdomain String?  @unique @db.VarChar(100)
  settings  Json     @default("{}")
  status    Int      @default(1)

  legalForm        String?  @map("legal_form")        @db.VarChar(50)
  inn              String?  @db.VarChar(20)
  kpp              String?  @db.VarChar(20)
  ogrn             String?  @db.VarChar(20)
  legalAddress     String?  @map("legal_address")
  actualAddress    String?  @map("actual_address")
  phone            String?  @db.VarChar(50)
  phoneExt         String?  @map("phone_ext")         @db.VarChar(20)
  email            String?  @db.VarChar(255)
  directorUserId   Int?     @map("director_user_id")
  accountantUserId Int?     @map("accountant_user_id")

  directorNameText   String? @map("director_name_text")   @db.VarChar(255)
  directorPosition   String? @map("director_position")    @db.VarChar(255)
  accountantNameText String? @map("accountant_name_text") @db.VarChar(255)
  accountantPosition String? @map("accountant_position")  @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  bankAccounts CompanyBankAccount[]

  @@map("accounts")
}

model CompanyBankAccount {
  id                   Int      @id @default(autoincrement())
  accountId            Int      @map("account_id")
  bankName             String   @map("bank_name")             @db.VarChar(255)
  bik                  String?  @db.VarChar(20)
  settlementAccount    String?  @map("settlement_account")    @db.VarChar(50)
  correspondentAccount String?  @map("correspondent_account") @db.VarChar(50)
  bankInn              String?  @map("bank_inn")              @db.VarChar(20)
  bankAddress          String?  @map("bank_address")
  createdAt            DateTime @default(now())               @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt    @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("company_bank_accounts")
}

model User {
  id                   Int      @id @default(autoincrement())
  accountId            Int      @map("account_id")
  roleId               Int?     @map("role_id")
  name                 String   @db.VarChar(255)
  email                String   @unique @db.VarChar(255)
  settings             Json     @default("{}")
  notificationSettings Json     @default("{}") @map("notification_settings")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([accountId])
  @@map("users")
}

model PriceProjectCategory {
  id        Int      @id @default(autoincrement())
  accountId Int      @map("account_id")
  name      String   @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  prices PriceItemPrice[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("price_project_categories")
}

model PriceCategory {
  id          Int      @id @default(autoincrement())
  accountId   Int      @map("account_id")
  name        String   @db.VarChar(255)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  items PriceItem[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("price_categories")
}

model PriceItem {
  id          Int      @id @default(autoincrement())
  accountId   Int      @map("account_id")
  categoryId  Int?     @map("category_id")
  parentId    Int?     @map("parent_id")
  name        String   @db.VarChar(500)
  description String?
  unit        String?  @db.VarChar(50)
  cost        Decimal? @db.Decimal(14, 2)
  basePrice   Decimal? @map("base_price") @db.Decimal(14, 2)
  status      String   @default("active") @db.VarChar(20)
  calcMethod  String   @default("columns") @map("calc_method") @db.VarChar(20)
  rounding    Int      @default(0)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  category    PriceCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parent      PriceItem?             @relation("PriceItemModifiers", fields: [parentId], references: [id], onDelete: Cascade)
  modifiers   PriceItem[]            @relation("PriceItemModifiers")
  prices      PriceItemPrice[]
  paramGroups PriceItemParamGroup[]

  @@index([accountId])
  @@index([categoryId])
  @@index([parentId])
  @@map("price_items")
}

model PriceUnit {
  id        Int      @id @default(autoincrement())
  accountId Int      @map("account_id")
  name      String   @db.VarChar(100)
  shortName String?  @map("short_name") @db.VarChar(30)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([accountId, name])
  @@index([accountId])
  @@map("price_units")
}

model PriceParameter {
  id            Int      @id @default(autoincrement())
  accountId     Int      @map("account_id")
  name          String   @db.VarChar(255)
  selectionType String   @default("single") @map("selection_type") @db.VarChar(10)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  values PriceParameterValue[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("price_parameters")
}

model PriceParameterValue {
  id             Int      @id @default(autoincrement())
  parameterId    Int      @map("parameter_id")
  name           String   @db.VarChar(255)
  influenceType  String   @default("coefficient") @map("influence_type") @db.VarChar(12)
  influenceValue Decimal  @default(1) @map("influence_value") @db.Decimal(14, 4)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  parameter PriceParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@index([parameterId])
  @@map("price_parameter_values")
}

model PriceItemParamGroup {
  id                Int      @id @default(autoincrement())
  itemId            Int      @map("item_id")
  sourceParameterId Int?     @map("source_parameter_id")
  name              String   @db.VarChar(255)
  selectionType     String   @default("single") @map("selection_type") @db.VarChar(10)
  isRequired        Boolean  @default(true) @map("is_required")
  affectsPrice      Boolean  @default(true) @map("affects_price")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  item    PriceItem               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options PriceItemParamOption[]

  @@index([itemId])
  @@index([sourceParameterId])
  @@map("price_item_param_groups")
}

model PriceItemParamOption {
  id             Int      @id @default(autoincrement())
  groupId        Int      @map("group_id")
  name           String   @db.VarChar(255)
  influenceType  String   @default("coefficient") @map("influence_type") @db.VarChar(12)
  influenceValue Decimal  @default(1) @map("influence_value") @db.Decimal(14, 4)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  group PriceItemParamGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("price_item_param_options")
}

model PriceItemPrice {
  id                Int      @id @default(autoincrement())
  itemId            Int      @map("item_id")
  projectCategoryId Int      @map("project_category_id")
  price             Decimal  @db.Decimal(14, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  item            PriceItem            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  projectCategory PriceProjectCategory @relation(fields: [projectCategoryId], references: [id], onDelete: Cascade)

  @@unique([itemId, projectCategoryId])
  @@index([itemId])
  @@index([projectCategoryId])
  @@map("price_item_prices")
}
