generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id Int @id @default(autoincrement())
  name String @db.VarChar(255)
  status Int @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  wikiPages WikiPage[]
  @@map("accounts")
}

model WikiPage {
  id Int @id @default(autoincrement())
  accountId Int @map("account_id")
  title String @db.VarChar(255)
  slug String? @unique @db.VarChar(255)
  content String? @db.Text
  blocks Json @default("[]")
  category String? @db.VarChar(100)
  parentPageId Int? @map("parent_page_id")
  version Int @default(1)
  createdByUserId Int? @map("created_by_user_id")
  updatedByUserId Int? @map("updated_by_user_id")
  isPublic Boolean @default(true) @map("is_public")
  allowedRoles Json @default("[]") @map("allowed_roles")
  tags Json @default("[]")
  attachments Json @default("[]")
  viewCount Int @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parentPage WikiPage? @relation("WikiPageHierarchy", fields: [parentPageId], references: [id])
  childPages WikiPage[] @relation("WikiPageHierarchy")
  versions WikiPageVersion[]
  drafts WikiPageDraft[]
  childDrafts WikiPageDraft[] @relation("DraftParentPage")
  @@index([accountId])
  @@index([category])
  @@map("wiki_pages")
}

model WikiPageVersion {
  id               Int      @id @default(autoincrement())
  wikiPageId       Int      @map("wiki_page_id")
  versionNum       Int      @default(1) @map("version_num")
  title            String   @db.VarChar(255)
  blocks           Json     @default("[]")
  changeNote       String?  @db.Text @map("change_note")
  createdByUserId  Int?     @map("created_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  page WikiPage @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)

  @@unique([wikiPageId, versionNum])
  @@index([wikiPageId])
  @@map("wiki_page_versions")
}

model WikiPageDraft {
  id            Int      @id @default(autoincrement())
  wikiPageId    Int?     @map("wiki_page_id")
  accountId     Int      @map("account_id")
  title         String   @db.VarChar(255)
  category      String?  @db.VarChar(100)
  parentPageId  Int?     @map("parent_page_id")
  tags          Json     @default("[]")
  blocks        Json     @default("[]")
  status        String   @default("draft") @db.VarChar(32)
  authorId      Int      @map("author_id")
  reviewerId    Int?     @map("reviewer_id")
  reviewNote    String?  @db.Text @map("review_note")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  page       WikiPage?  @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)
  parentPage WikiPage?  @relation("DraftParentPage", fields: [parentPageId], references: [id], onDelete: SetNull)
  comments   WikiDraftComment[]

  @@index([accountId])
  @@index([status])
  @@index([authorId])
  @@map("wiki_page_drafts")
}

model WikiDraftComment {
  id        Int      @id @default(autoincrement())
  draftId   Int      @map("draft_id")
  userId    Int      @map("user_id")
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  draft WikiPageDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@map("wiki_draft_comments")
}

// ─── Construction Wiki (Строительная ВИКИ) — global normative base ───
// СНИПы / ГОСТы / СП — национальные стандарты, общие для всех аккаунтов.
// Контент не изолируется по accountId; запись разрешена только super_admin.

model NormCategory {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  slug        String?  @db.VarChar(255)
  description String?  @db.Text
  icon        String?  @db.VarChar(64)
  parentId    Int?     @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  parent   NormCategory?  @relation("NormCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children NormCategory[] @relation("NormCategoryTree")
  documents NormDocument[]

  @@index([parentId])
  @@map("norm_categories")
}

model NormDocument {
  id              Int       @id @default(autoincrement())
  categoryId      Int?      @map("category_id")
  docType         String    @default("other") @map("doc_type") @db.VarChar(32) // snip | gost | sp | regional | other
  code            String?   @db.VarChar(120) // обозначение, напр. "СП 48.13330.2019"
  title           String    @db.VarChar(500)
  summary         String?   @db.Text
  content         String?   @db.Text // структурный текст (Markdown)
  status          String    @default("active") @db.VarChar(32) // active | superseded | draft
  effectiveDate   DateTime? @map("effective_date") @db.Date
  supersededDate  DateTime? @map("superseded_date") @db.Date
  supersededById  Int?      @map("superseded_by_id")
  tags            Json      @default("[]")
  attachments     Json      @default("[]")
  relatedIds      Json      @default("[]") @map("related_ids")
  keywords        String?   @db.Text
  viewCount       Int       @default(0) @map("view_count")
  createdByUserId Int?      @map("created_by_user_id")
  updatedByUserId Int?      @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  category     NormCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supersededBy NormDocument?  @relation("NormSupersede", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes   NormDocument[] @relation("NormSupersede")
  bookmarks    NormBookmark[]

  @@index([categoryId])
  @@index([docType])
  @@index([status])
  @@map("norm_documents")
}

model NormBookmark {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  documentId Int      @map("document_id")
  createdAt  DateTime @default(now()) @map("created_at")

  document NormDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId])
  @@map("norm_bookmarks")
}
